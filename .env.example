# needed now
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# needed for dbt (prep)
DATABASE_URL=

# needed for the agents (day-of)
# Run-time inference for the swarm. Any OpenAI-compatible endpoint. If unset, the
# swarm runs on the deterministic scripted policies (still fully autonomous).
INFERENCE_API_KEY=
INFERENCE_BASE_URL=https://openrouter.ai/api/v1
INFERENCE_MODEL=openai/gpt-4o-mini
INFERENCE_MODEL_CEO=openai/gpt-4o

# Human approval gate (optional). Without any of these the gate still records to
# pending_approvals and the dashboard renders it; with them the founder's phone buzzes.
# Channels are tried in priority order: Wassist (WhatsApp) -> Telegram -> dashboard-only.

# Wassist (sponsor): message your deployed assistant once to create a conversation,
# then copy its id from Settings. API key: Settings -> API Keys.
WASSIST_API_KEY=
WASSIST_CONVERSATION_ID=
WASSIST_BASE_URL=https://backend.wassist.app

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
